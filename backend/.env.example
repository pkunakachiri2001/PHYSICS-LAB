# ── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ── Database (MongoDB Atlas) ─────────────────────────────────────
# Create free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/smart_ar_physics_lab?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://your-project-name.vercel.app

# ── Bcrypt ───────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
